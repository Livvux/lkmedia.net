---
interface Card { title: string; metric: string; body: string; gradient?: string }
interface Props { items: Card[] }
const { items } = Astro.props;
const gradients = [
  'from-sky-400 via-cyan-300 to-emerald-300',
  'from-fuchsia-400 via-pink-400 to-amber-300',
  'from-violet-400 via-indigo-400 to-sky-300',
];
---
<section class="py-32 px-6">
  <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-6" data-value-grid>
    {items.map((c, i) => (
      <article
        class="value-card rounded-3xl bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 p-8 transition-all duration-700 ease-out will-change-transform hover:-translate-y-1 hover:border-black/20 dark:border-white/20 hover:bg-black/[0.07] dark:hover:bg-white/[0.07]"
        style={`transition-delay:${i * 120}ms`}
      >
        <div class={`text-5xl font-semibold tracking-tight bg-gradient-to-r ${c.gradient ?? gradients[i % gradients.length]} bg-clip-text text-transparent`}>{c.metric}</div>
        <h3 class="mt-6 text-xl font-medium">{c.title}</h3>
        <p class="mt-2 text-black/60 dark:text-white/60">{c.body}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .value-card { opacity: 1; transform: translateY(0); }
  .value-card.will-animate { opacity: 0; transform: translateY(24px); }
  .value-card.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .value-card { transition: none !important; }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.value-card');
  if (cards.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    cards.forEach((el) => el.classList.add('will-animate'));
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.remove('will-animate');
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.2, rootMargin: '0px 0px -10% 0px' });
    cards.forEach((el) => io.observe(el));
  }
</script>
