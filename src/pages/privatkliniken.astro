---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/landing/Hero.astro';
import CTABlock from '../components/landing/CTABlock.astro';
import FaqBlock from '../components/FaqBlock.astro';

const seo = {
  title: 'Privatklinik Website — Premium-Auftritte für Kliniken',
  description: 'Privatklinik-Websites, die Patienten gewinnen. Seriöse, HWG-konforme Premium-Auftritte für Ästhetik, Orthopädie und Zahnmedizin.',
  canonical: '/privatkliniken',
  lang: 'de' as const,
  alternateUrls: { de: 'https://lkmedia.net/privatkliniken' },
};

const pains = [
  { title: 'Kein HWG-konformes Marketing', body: 'Werbeaussagen riskieren Abmahnungen, weil das Heilmittelwerbegesetz nicht sauber umgesetzt ist.' },
  { title: 'Vertrauen fehlt', body: 'Der Auftritt wirkt wie eine durchschnittliche Praxis — nicht wie eine Premium-Klinik mit Spezialisierung.' },
  { title: 'Patientenanfragen versanden', body: 'Kontaktformulare ohne Flow, keine Vorqualifizierung, keine Terminbuchung — Interessenten gehen verloren.' },
];

const features = [
  { title: 'HWG-konformes Copywriting', body: 'Texte, die klare Positionierung zeigen — ohne unzulässige Heilversprechen oder Werbeaussagen.' },
  { title: 'Arzt-Profile', body: 'E-E-A-T-starke Profile mit Qualifikationen, Publikationen und Fachbereichen — Vertrauen auf den ersten Blick.' },
  { title: 'Terminbuchung', body: 'Direkte Online-Buchung mit Vorqualifizierung — integriert mit gängigen Praxisverwaltungen oder Cal.com.' },
  { title: 'Patientenstimmen-Framework', body: 'Strukturierte, rechtssichere Erfahrungsberichte — anonymisiert, verifiziert, HWG-konform.' },
  { title: 'Mehrsprachigkeit', body: 'DE / EN / AR für internationale Selbstzahler und Medical-Tourism-Anfragen.' },
];

const faqs = [
  { q: 'Was ist beim HWG zu beachten?', a: 'Werbung für bestimmte Heilverfahren, Vorher-Nachher-Bilder bei operativen Eingriffen und bestimmte Wirkaussagen sind streng reguliert. Wir bauen Struktur, Copy und Bildsprache entlang der aktuellen Rechtslage — inkl. Fachanwalts-Review bei sensiblen Bereichen.' },
  { q: 'Wie lange dauert das Projekt?', a: 'Ein vollständiger Relaunch liegt typischerweise bei 10–14 Wochen. Die Anzahl der Fachbereiche, Arzt-Profile und Sprachen bestimmen den genauen Rahmen.' },
  { q: 'Was kostet eine Privatklinik-Website?', a: 'Projekte starten bei 25k € als Fixpreis auf Scope. Mehrsprachigkeit, Terminbuchungs-Integration oder mehrere Standorte werden individuell kalkuliert.' },
  { q: 'Wie gehen Sie mit Patientendaten und DSGVO um?', a: 'Kontaktformulare und Terminbuchung laufen über DSGVO-konforme, EU-gehostete Dienste. Keine US-Tracker, keine unsauberen Cookie-Banner. Datenschutzerklärung wird mit Ihrem DSB abgestimmt.' },
];

const allCases = await getCollection('cases');
const relatedCase = allCases.find((c) => c.data.niche === 'anwaelte') ?? allCases.find((c) => c.data.niche === 'luxus-immobilien');

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Privatklinik Website — Premium Web Development',
  provider: { '@type': 'Organization', name: 'lkmedia', url: 'https://lkmedia.net' },
  areaServed: 'DE',
  serviceType: 'Privatklinik-Website',
  url: 'https://lkmedia.net/privatkliniken',
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((i) => ({
    '@type': 'Question',
    name: i.q,
    acceptedAnswer: { '@type': 'Answer', text: i.a },
  })),
};
---
<Base seo={seo} jsonLd={[serviceSchema, faqSchema]}>
  <Hero
    headline="Privatklinik-Websites, die Patienten gewinnen."
    sub="Seriöse, medizinrechtlich saubere Premium-Auftritte für Ästhetik, Orthopädie, Zahnmedizin."
    ctaHref="/kontakt" ctaLabel="Projekt starten" />

  <section class="py-24 px-6 max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-5xl font-semibold tracking-tight mb-12">Was im Klinik-Segment online fehlt.</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {pains.map((p) => (
        <div class="rounded-2xl border border-red-500/20 bg-red-500/5 p-8">
          <div class="text-red-400/80 text-sm tracking-widest mb-4">PAIN</div>
          <h3 class="text-xl font-semibold mb-3">{p.title}</h3>
          <p class="text-white/70 leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 max-w-6xl mx-auto border-t border-white/10">
    <h2 class="text-3xl md:text-5xl font-semibold tracking-tight mb-12">Was eine Privatklinik-Website leisten muss.</h2>
    <div class="grid md:grid-cols-2 gap-10">
      {features.map((f) => (
        <div>
          <h3 class="text-xl font-semibold mb-3">{f.title}</h3>
          <p class="text-white/70 leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  {relatedCase && (
    <section class="py-24 px-6 max-w-6xl mx-auto border-t border-white/10">
      <div class="text-white/40 text-sm tracking-widest mb-6">ÄHNLICHER PREMIUM-AUFTRITT</div>
      <a href={`/cases/${relatedCase.id}`} class="group block">
        <div class="aspect-[16/7] rounded-2xl overflow-hidden bg-white/5 mb-6">
          <img src={relatedCase.data.heroImage} alt={relatedCase.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <h3 class="text-2xl md:text-4xl font-semibold tracking-tight">{relatedCase.data.title}</h3>
        <p class="mt-3 text-white/70 max-w-2xl">{relatedCase.data.summary}</p>
      </a>
    </section>
  )}

  <FaqBlock items={faqs} />

  <CTABlock headline="Bereit für mehr Patientenanfragen?"
    formHref="/kontakt" calHref="/kontakt#termin"
    formLabel="Projekt starten" calLabel="15 min Call" />
</Base>
