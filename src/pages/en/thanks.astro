---
import Base from '../../layouts/Base.astro';
const seo = {
  title: 'Thanks',
  description: 'Inquiry received — usually a reply within 24h.',
  canonical: '/en/thanks',
  lang: 'en' as const,
  noindex: true,
};
---
<Base seo={seo}>
  <section class="py-40 px-6 text-center max-w-2xl mx-auto">
    <h1 class="text-5xl md:text-7xl font-semibold tracking-tight">Thanks.</h1>
    <p class="mt-6 text-xl text-black/70 dark:text-white/70">Usually a reply within 24 hours.</p>
    <a href="/en/" class="inline-flex mt-10 h-12 px-6 items-center rounded-full border border-black/30 dark:border-white/30">Back to home</a>
  </section>
</Base>
