---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/landing/Hero.astro';
import CTABlock from '../../components/landing/CTABlock.astro';

const seo = {
  title: 'Services',
  description: 'Premium websites, SEO and conversion for law firms, luxury real estate and private clinics — by lkmedia.',
  canonical: '/en/leistungen',
  lang: 'en' as const,
  alternateUrls: { de: 'https://lkmedia.net/leistungen', en: 'https://lkmedia.net/en/leistungen' },
};

const services = [
  {
    n: '01',
    title: 'Website & Development',
    body: 'Handcrafted Astro sites with uncompromising performance. Every line of code earns its place.',
    items: ['Astro and modern web standards', 'Core Web Vitals in the green', 'WCAG accessibility', 'Schema.org and structured data'],
  },
  {
    n: '02',
    title: 'SEO & Content',
    body: 'Visibility that wins mandates — not just traffic. Content that both Google and AI assistants cite.',
    items: ['Keyword and intent strategy', 'Editorial-grade content briefs', 'E-E-A-T and author signals', 'AI Overviews and LLM visibility'],
  },
  {
    n: '03',
    title: 'Conversion & Marketing',
    body: 'Visitors become inquiries. Inquiries become clients. Measurable, iterative, scalable.',
    items: ['Focused landing pages', 'A/B tests on real signals', 'Funnels and lead nurturing', 'Reporting that drives decisions'],
  },
];
---
<Base seo={seo}>
  <Hero
    headline="Services."
    sub="Premium websites, SEO, conversion — one team."
    ctaHref="/en/contact" ctaLabel="Start a project" />

  {services.map((s, i) => (
    <section class="border-t border-black/10 dark:border-white/10 px-6 py-28 md:py-40">
      <div class="mx-auto max-w-6xl grid md:grid-cols-12 gap-10 md:gap-16 items-start">
        <div class={`md:col-span-5 ${i % 2 === 1 ? 'md:order-2' : ''}`}>
          <div class="text-black/30 dark:text-white/30 text-sm tracking-widest mb-6">{s.n}</div>
          <h2 class="text-4xl md:text-6xl font-semibold tracking-tight leading-[1.05]">{s.title}</h2>
        </div>
        <div class={`md:col-span-7 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
          <p class="text-lg md:text-2xl text-black/70 dark:text-white/70 leading-relaxed">{s.body}</p>
          <ul class="mt-10 space-y-4">
            {s.items.map((it) => (
              <li class="flex items-start gap-4 text-black/80 dark:text-white/80 text-lg">
                <span class="mt-2 h-px w-8 bg-black/30 dark:bg-white/30 flex-shrink-0"></span>
                <span>{it}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  ))}

  <section class="border-t border-black/10 dark:border-white/10 px-6 py-32 md:py-48 text-center">
    <div class="mx-auto max-w-3xl">
      <p class="text-3xl md:text-5xl font-semibold tracking-tight leading-[1.15]">
        Projects start at €25k. Fixed price by scope. No hourly billing.
      </p>
    </div>
  </section>

  <CTABlock headline="Ready to win more clients?"
    formHref="/en/contact" calHref="/en/contact#book"
    formLabel="Start a project" calLabel="15 min call" />
</Base>
