---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Hero from '../../components/landing/Hero.astro';
import CTABlock from '../../components/landing/CTABlock.astro';
import FaqBlock from '../../components/FaqBlock.astro';

const seo = {
  title: 'Law Firm Websites — Premium Sites for Law Firms',
  description: 'Law firm websites that win mandates. GDPR and professional-code compliant premium sites for commercial, IT and tax law.',
  canonical: '/en/anwaelte',
  lang: 'en' as const,
  alternateUrls: { de: 'https://lkmedia.net/anwaelte', en: 'https://lkmedia.net/en/anwaelte' },
};

const pains = [
  { title: 'Invisible online', body: 'Your firm does not rank for the mandates you want. Competitors appear on top — you do not.' },
  { title: 'No firm branding', body: 'The digital presence reflects neither your expertise nor your positioning in the premium segment.' },
  { title: 'Missing trust', body: 'First inquiries never arrive — or arrive unqualified — because trust is not built digitally.' },
];

const features = [
  { title: 'GDPR & professional code', body: 'Compliant implementation per BRAO, BORA and GDPR — including imprint with bar association.' },
  { title: 'Client portal ready', body: 'Prepared for secure document exchange and client login whenever you need it.' },
  { title: 'E-E-A-T author profiles', body: 'Partner and associate profiles with expertise signals that Google and AI assistants cite.' },
  { title: 'Team & practice pages', body: 'Structured overviews for practice groups, partners and specialties — clearly navigable.' },
  { title: 'Bar directory integration', body: 'Clean linking to BRAK and specialist directories for additional trust signals.' },
];

const faqs = [
  { q: 'Is law firm advertising allowed?', a: 'Yes — within § 43b BRAO and § 6 BORA. Factual information about professional activity is allowed; sensationalist or comparative advertising is not. We shape copy and claims exactly along that line.' },
  { q: 'Do I need an imprint with the bar association?', a: 'Yes. The imprint must list the responsible bar association, the professional title including the state of conferral, and the governing professional rules. Standard on every law firm site we build.' },
  { q: 'How long does a relaunch take?', a: 'A full relaunch is typically 8–12 weeks — from kickoff to go-live. Scope, number of attorney profiles and content volume determine the exact frame.' },
  { q: 'What does a law firm website cost?', a: 'Projects start at €25k as a fixed price on scope. Concept, design, build, copy and launch included. No hourly billing, no surprises.' },
];

const allCases = await getCollection('cases');
const relatedCase = allCases.find((c) => c.data.niche === 'anwaelte');

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Law Firm Website — Premium Web Development',
  provider: { '@type': 'Organization', name: 'lkmedia', url: 'https://lkmedia.net' },
  areaServed: 'DE',
  serviceType: 'Law Firm Website',
  url: 'https://lkmedia.net/en/anwaelte',
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((i) => ({
    '@type': 'Question',
    name: i.q,
    acceptedAnswer: { '@type': 'Answer', text: i.a },
  })),
};
---
<Base seo={seo} jsonLd={[serviceSchema, faqSchema]}>
  <Hero
    headline="Law firm websites that win mandates."
    sub="Digital premium sites for commercial, IT and tax law — GDPR and professional-code compliant."
    ctaHref="/en/kontakt" ctaLabel="Start a project" />

  <section class="py-24 px-6 max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-5xl font-semibold tracking-tight mb-12">Why firms come to us.</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {pains.map((p) => (
        <div class="rounded-2xl border border-red-500/20 bg-red-500/5 p-8">
          <div class="text-red-400/80 text-sm tracking-widest mb-4">PAIN</div>
          <h3 class="text-xl font-semibold mb-3">{p.title}</h3>
          <p class="text-white/70 leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 max-w-6xl mx-auto border-t border-white/10">
    <h2 class="text-3xl md:text-5xl font-semibold tracking-tight mb-12">What a law firm website has to deliver today.</h2>
    <div class="grid md:grid-cols-2 gap-10">
      {features.map((f) => (
        <div>
          <h3 class="text-xl font-semibold mb-3">{f.title}</h3>
          <p class="text-white/70 leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  {relatedCase && (
    <section class="py-24 px-6 max-w-6xl mx-auto border-t border-white/10">
      <div class="text-white/40 text-sm tracking-widest mb-6">PROJECT</div>
      <a href={`/en/cases/${relatedCase.id}`} class="group block">
        <div class="aspect-[16/7] rounded-2xl overflow-hidden bg-white/5 mb-6">
          <img src={relatedCase.data.heroImage} alt={relatedCase.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <h3 class="text-2xl md:text-4xl font-semibold tracking-tight">{relatedCase.data.title}</h3>
        <p class="mt-3 text-white/70 max-w-2xl">{relatedCase.data.summary}</p>
      </a>
    </section>
  )}

  <FaqBlock items={faqs} />

  <CTABlock headline="Ready for more mandates?"
    formHref="/en/kontakt" calHref="/en/kontakt#termin"
    formLabel="Start a project" calLabel="15 min call" />
</Base>
