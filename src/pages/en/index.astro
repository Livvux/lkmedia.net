---
import Base from '../../layouts/Base.astro';
import HeroShowcase from '../../components/landing/HeroShowcase.astro';
import NicheTiles from '../../components/landing/NicheTiles.astro';
import CaseTeaser from '../../components/landing/CaseTeaser.astro';
import Process from '../../components/landing/Process.astro';
import SocialProof from '../../components/landing/SocialProof.astro';
import CTABlock from '../../components/landing/CTABlock.astro';
import { professionalService } from '../../lib/schema';

const seo = {
  title: 'Premium websites that win clients',
  description: 'lkmedia builds Apple-grade websites for law firms, luxury real estate and private clinics — with perfect SEO and Lighthouse 100.',
  canonical: '/en/',
  lang: 'en' as const,
  alternateUrls: { de: 'https://lkmedia.net/', en: 'https://lkmedia.net/en/' },
};
---
<Base seo={seo} jsonLd={[professionalService()]}>
  <HeroShowcase
    headline="Premium websites that win clients."
    sub="Apple-grade design. Lighthouse 100. Conversion-optimised."
    ctaHref="/en/contact" ctaLabel="Start a project"
    secondaryHref="/en/contact#book" secondaryLabel="15 min call"
    image="/landing/device.webp"
    alt="Client project: Klavierbau Hans Milde"
    deviceHref="https://klavierbau-milde.de"
    features={[
      { label: '<1s', sub: 'LCP under one second on 4G. Lighthouse 100.' },
      { label: 'A+', sub: 'Apple-grade typography, whitespace, finish.' },
      { label: '100', sub: 'Perfect Lighthouse. E-E-A-T-ready. AI-overview-ready.' },
      { label: 'WCAG', sub: 'Accessible per BITV 2.0 / WCAG 2.2.' },
    ]}
  />
  <NicheTiles items={[
    { href: '/en/law-firms', label: 'Law Firms', image: '/landing/niche-law.svg' },
    { href: '/en/luxury-real-estate', label: 'Luxury Real Estate', image: '/landing/niche-realestate.svg' },
    { href: '/en/private-clinics', label: 'Private Clinics', image: '/landing/niche-clinic.svg' },
  ]} />
  <CaseTeaser lang="en" />
  <Process items={[
    { n: '01', title: 'Brief', body: 'Kickoff, goals, audience, KPIs.' },
    { n: '02', title: 'Design', body: 'Concept, Figma prototype, copy.' },
    { n: '03', title: 'Build', body: 'Astro, code, content, performance.' },
    { n: '04', title: 'Launch', body: 'Deploy, Search Console, monitoring.' },
  ]} />
  <CTABlock headline="Ready to win more clients?"
    formHref="/en/contact" calHref="/en/contact#book"
    formLabel="Start a project" calLabel="15 min call" />
</Base>
