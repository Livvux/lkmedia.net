---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const all = await getCollection('cases');
const cases = all.sort((a, b) => +b.data.pubDate - +a.data.pubDate);
const nicheLabel: Record<string, string> = {
  anwaelte: 'Kanzlei',
  'luxus-immobilien': 'Luxus-Immobilien',
  privatkliniken: 'Privatklinik',
  fintech: 'Fintech',
  other: 'Premium',
};
const seo = {
  title: 'Cases',
  description: 'Ausgewählte Projekte: Kanzleien, Luxus-Immobilien, Premium-Marken.',
  canonical: '/cases',
  lang: 'de' as const,
  alternateUrls: { de: 'https://lkmedia.net/cases', en: 'https://lkmedia.net/en/cases' },
};
---
<Base seo={seo}>
  <section class="py-32 px-6 max-w-6xl mx-auto">
    <h1 class="text-5xl md:text-7xl font-semibold tracking-tight">Cases.</h1>
    <div class="mt-16 grid md:grid-cols-2 gap-8">
      {cases.map((c) => (
        <a href={`/cases/${c.id}`} class="group block">
          <div class="aspect-[16/9] rounded-2xl overflow-hidden bg-black/5 dark:bg-white/5">
            <img src={c.data.heroImage} alt={c.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="mt-4 text-sm uppercase tracking-wider text-black/50 dark:text-white/50">{nicheLabel[c.data.niche] ?? c.data.niche}</div>
          <div class="text-2xl font-medium mt-1">{c.data.title}</div>
          <div class="text-black/60 dark:text-white/60 mt-1">{c.data.summary}</div>
        </a>
      ))}
    </div>
  </section>
</Base>
