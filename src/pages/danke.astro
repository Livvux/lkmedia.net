---
import Base from '../layouts/Base.astro';
const seo = {
  title: 'Danke',
  description: 'Anfrage erhalten — Antwort meist innerhalb 24h.',
  canonical: '/danke',
  lang: 'de' as const,
  noindex: true,
};
---
<Base seo={seo}>
  <section class="py-40 px-6 text-center max-w-2xl mx-auto">
    <h1 class="text-5xl md:text-7xl font-semibold tracking-tight">Danke.</h1>
    <p class="mt-6 text-xl text-white/70">Antwort meist innerhalb von 24 Stunden.</p>
    <a href="/" class="inline-flex mt-10 h-12 px-6 items-center rounded-full border border-white/30">Zurück zur Startseite</a>
  </section>
</Base>
