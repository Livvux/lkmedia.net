---
import Base from './Base.astro';
import { breadcrumbs, blogPosting } from '../lib/schema';
import type { SeoProps } from '../lib/seo';

interface Props { entry: any; lang: 'de' | 'en' }
const { entry, lang } = Astro.props as Props;
const slug = entry.id.replace(/^(de|en)\//, '');
const url = entry.data.route === 'root'
  ? (lang === 'de' ? `/${slug}/` : `/en/${slug}/`)
  : (lang === 'de' ? `/blog/${slug}/` : `/en/blog/${slug}/`);
const blogIndex = lang === 'de' ? '/blog' : '/en/blog';
const seo: SeoProps = {
  title: entry.data.title,
  description: entry.data.description,
  canonical: url,
  lang,
  ogImage: entry.data.ogImage,
};
const bc = breadcrumbs([
  { name: 'Home', url: 'https://lkmedia.net/' },
  { name: 'Blog', url: `https://lkmedia.net${blogIndex}` },
  { name: entry.data.title, url: `https://lkmedia.net${url}` },
]);
const bp = blogPosting({
  title: entry.data.title,
  description: entry.data.description,
  pubDate: entry.data.pubDate,
  updatedDate: entry.data.updatedDate,
  author: entry.data.author,
  image: entry.data.ogImage,
  url: `https://lkmedia.net${url}`,
});
---
<Base seo={seo} jsonLd={[bc, bp]}>
  <article class="max-w-3xl mx-auto px-6 py-32 prose prose-invert prose-lg">
    <nav class="text-sm text-white/50 mb-8 not-prose">
      <a href={blogIndex}>← Blog</a>
    </nav>
    <h1 class="text-4xl md:text-6xl font-semibold tracking-tight">{entry.data.title}</h1>
    <div class="text-sm text-white/50 mt-4 not-prose">
      {entry.data.pubDate.toISOString().slice(0, 10)} · {entry.data.author}
    </div>
    <div class="mt-10"><slot /></div>
    <footer class="mt-20 border-t border-white/10 pt-8 text-sm text-white/50 not-prose">
      {lang === 'de' ? 'Geschrieben von' : 'Written by'} {entry.data.author}.
    </footer>
  </article>
</Base>
